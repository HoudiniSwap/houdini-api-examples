# Reown AppKit — get your project ID at https://dashboard.reown.com
NEXT_PUBLIC_PROJECT_ID=your_project_id_here

# Houdini API Credentials (server-side only — never expose to the browser)
HOUDINI_API_KEY=your_api_key_here
HOUDINI_API_SECRET=your_api_secret_here

# Houdini API base URL (defaults shown — override to point to staging/dev)
HOUDINI_API_BASE_URL=https://api-partner.houdiniswap.com

# Optional: Override RPC endpoints (defaults to public RPCs)
# ETHEREUM_RPC_URL=https://eth.llamarpc.com
# BASE_RPC_URL=https://mainnet.base.org
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# POLYGON_RPC_URL=https://polygon-rpc.com
# OPTIMISM_RPC_URL=https://mainnet.optimism.io
